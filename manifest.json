{
  "manifest_version": 3,
  "name": "Tab Manager - Rename & Switch",
  "version": "1.0.0",
  "description": "Rename tabs and switch between recently used tabs with a visual overlay.",
  "permissions": [
    "tabs",
    "tabGroups",
    "activeTab",
    "storage",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "switch-tab-forward": {
      "suggested_key": {
        "default": "Alt+S",
        "mac": "Alt+S"
      },
      "description": "Open tab switcher (forward)"
    },
    "switch-tab-backward": {
      "description": "Open tab switcher (backward) — set shortcut in chrome://extensions/shortcuts"
    },
    "rename-tab": {
      "suggested_key": {
        "default": "Alt+R",
        "mac": "Alt+R"
      },
      "description": "Rename current tab"
    },
    "duplicate-tab": {
      "suggested_key": {
        "default": "Ctrl+E",
        "mac": "Command+E"
      },
      "description": "Duplicate current tab"
    },
    "move-tab-up": {
      "description": "Go one tab up (Ctrl+Option+Up)"
    },
    "move-tab-down": {
      "description": "Go one tab down (Ctrl+Option+Down)"
    },
    "back-to-pinned": {
      "suggested_key": {
        "default": "Alt+P",
        "mac": "Alt+P"
      },
      "description": "Back to pinned URL"
    },
    "set-pinned-url": {
      "description": "Set current URL as pinned — set shortcut in chrome://extensions/shortcuts"
    }
  },
  "action": {
    "default_title": "Rename this tab",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
